# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# WhatsApp Cloud API (Meta)
# ─────────────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_API_VERSION=v21.0

# ─────────────────────────────────────────────
# Instagram Graph API (Meta)
# ─────────────────────────────────────────────
INSTAGRAM_TOKEN=your-instagram-access-token
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_VERIFY_TOKEN=your-custom-verify-token

# ─────────────────────────────────────────────
# Telegram Bot API
# ─────────────────────────────────────────────
TELEGRAM_TOKEN=your-telegram-bot-token

# ─────────────────────────────────────────────
# Messenger Platform
# ─────────────────────────────────────────────
MESSENGER_TOKEN=your-messenger-page-access-token
MESSENGER_APP_SECRET=your-messenger-app-secret
MESSENGER_VERIFY_TOKEN=your-custom-verify-token

# ─────────────────────────────────────────────
# Salla Integration
# ─────────────────────────────────────────────
SALLA_WEBHOOK_SECRET=your-salla-webhook-secret
SALLA_API_KEY=your-salla-api-key
SALLA_STORE_URL=https://your-store.salla.sa
